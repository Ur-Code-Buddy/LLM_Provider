# Copy to .env and fill in. Do not commit .env.

# Required — LiteLLM admin (must start with sk-)
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-secret

# Postgres (must match DATABASE_URL)
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# Provider keys (set what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# Optional
LITELLM_SALT_KEY=
LITELLM_HOST_PORT=4000
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_CLASSIFIER_MODEL=deepseek-chat
GATEWAY_CLASSIFIER_TTL_SECONDS=604800
GATEWAY_DEEPSEEK_API_BASE=https://api.deepseek.com
GATEWAY_BASIC_MODEL=deepseek/deepseek-chat
GATEWAY_PREMIUM_MODEL=anthropic/claude-sonnet-4-20250514
GATEWAY_FALLBACK_MODEL=openai/gpt-4o
GATEWAY_KIMI_MODEL=openai/moonshot-v1-8k
GATEWAY_KIMI_API_BASE=https://api.moonshot.cn/v1

# Cloudflare Tunnel (profile: tunnel)
CF_TUNNEL_TOKEN=

# Static UI port (profile: ui)
GATEWAY_UI_PORT=8080
