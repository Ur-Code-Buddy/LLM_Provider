# Copy to .env and fill in. Do not commit .env.

# Required — LiteLLM admin (must start with sk-)
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-secret

# Postgres (must match DATABASE_URL)
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# Provider keys (set what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# Resend (proxy email callback `resend_email` in config/proxy_config.yaml)
RESEND_API_KEY=

# Public URL of this proxy (no trailing slash). Required for SSO redirect URIs (`/sso/callback`).
PROXY_BASE_URL=http://localhost:4000

# Optional — LiteLLM native UI SSO (see LiteLLM "SSO for Admin UI" docs).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT=
# GENERIC_CLIENT_ID=
# GENERIC_CLIENT_SECRET=
# GENERIC_AUTHORIZATION_ENDPOINT=
# GENERIC_TOKEN_ENDPOINT=
# GENERIC_USERINFO_ENDPOINT=

# Optional — web SPA build overrides (normally same-origin `/ui`).
# VITE_LITELLM_UI_URL=
# VITE_LITELLM_DIRECT_URL=http://127.0.0.1:4001

# Optional
LITELLM_SALT_KEY=
LITELLM_HOST_PORT=4001
GATEWAY_REDIS_URL=redis://redis:6379/0
GATEWAY_CLASSIFIER_MODEL=deepseek-chat
GATEWAY_CLASSIFIER_TTL_SECONDS=604800
GATEWAY_DEEPSEEK_API_BASE=https://api.deepseek.com
GATEWAY_BASIC_MODEL=deepseek/deepseek-chat
GATEWAY_PREMIUM_MODEL=anthropic/claude-sonnet-4-20250514
GATEWAY_FALLBACK_MODEL=openai/gpt-4o
GATEWAY_KIMI_MODEL=openai/moonshot-v1-8k
GATEWAY_KIMI_API_BASE=https://api.moonshot.cn/v1

# Cloudflare Tunnel (profile: tunnel)
CF_TUNNEL_TOKEN=

# Static UI port (default public entrypoint)
GATEWAY_UI_PORT=4000
